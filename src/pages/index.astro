		dark:decoration-frost1
		hover:underline
		underline-offset-2
		hover:bg-aurora0
		dark:hover:bg-frost1
		hover:bg-opacity-10			
		dark:hover:bg-opacity-10			
		focus:outline-none
		focus-visible:ring-4
		rounded-md
		group
		ring-aurora0
	dark:ring-frost1
		ring-offset-4
	ring-offset-snow2
	dark:ring-offset-night0        
		">
		<svg role="img" class="w-8 h-8 mr-3 transition stroke-transparent fill-aurora0 dark:fill-frost1" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Gmail</title><path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/></svg>
