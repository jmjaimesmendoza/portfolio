---
import SiteLayout from "../layouts/SiteLayout.astro";
import Card from "../components/Card.astro";
import SkillList from "../components/SkillList.astro";
import AnimatedTitle from "../components/AnimatedTitle.astro";

const workingIcons =[{title:'Typescript',file:'typescript'},
      {title:'React',file:'react'},
      {title:'Git',file:'git'},
      {title:'MySQL',file:'mysql'},
      {title:'Node',file:'nodejs'}]
const workedIcons =[
      {title:'Python',file:'python'},
      {title:'.NET',file:'dotnet'},
      {title:'NestJS',file:'nest'},
      {title:'Expo',file:'expo'},
      {title:'Arduino',file:'arduino'},
			]
const learningIcons =[
      {title:'Svelte',file:'svelte'},
      	{title:'Astro',file:'astro'},
      {title:'Pandas',file:'pandas'},
			]
	const cardlist = [
	{
		img:'',
		linkTo:'/pernix', 
		title: 'My time at Pernix', 
		body: 'Learn more about my work at Pernix Solutions as an intern.'
	},
	{
		img:'',
		linkTo:'/2train', 
		title: 'My internship at 2Train', 
		body: 'Learn more about my time as intern working on the 2train app.'
	},
	{
		img:'',
		linkTo:'/conectaEquipo', 
		title: 'The ConectaEquipos App', 
		body: 'Let me tell you how I built an IoT monitoring app, twice.'
	},
	{
		img:'',
		linkTo:'/archive', 
		title: 'Other personal projects', 
		body: 'A collection of miscellaneous projects I worked on.'
	},
]
---
<SiteLayout>
	<div class={"justify-start items-start"}>
		<img src="./landscape.jpeg" alt="">
		<AnimatedTitle />
		<h2 class="text-xl -mt-4 md:mt-4 md:text-3xl lg:text-4xl text-aurora0 dark:text-frost1">Fullstack Web Developer / Computer Science Student</h2>
	</div>
	<div class="mt-4 flex flex-col gap-4 md:gap-8 md:flex-row mx-2 text-justify">
		<p class="max-w-lg">Hi there!, my name is Juan Martin Jaimes Mendoza and I'm a Full-Stack developer based in San José, Costa Rica. I have worked as a freelancer for a while now and also done two internships, one at Pernix Solutions and the other working at 2Train, you can find the details on those <a class="text-aurora3 dark:text-frost1 hover:underline underline-offset-2 rounded-md
			focus-visible:ring-4
			focus:outline-none
			ring-aurora0
		dark:ring-frost1
			ring-offset-4
		ring-offset-snow2
		dark:ring-offset-night0" href="/pernix"> here</a> and <a class="text-aurora3 dark:text-frost1 hover:underline underline-offset-2 rounded-md
		focus-visible:ring-4
		focus:outline-none
		ring-aurora0
	dark:ring-frost1
		ring-offset-4
	ring-offset-snow2
	dark:ring-offset-night0" href="/2train">here</a>, respectively.</p>
		<p class="max-w-lg">I'm also a student currently enrolled on my last semester of <a class="text-aurora3 dark:text-frost1 hover:underline underline-offset-2 rounded-md
		focus-visible:ring-4
		focus:outline-none
		ring-aurora0
	dark:ring-frost1
		ring-offset-4
	ring-offset-snow2
	dark:ring-offset-night0" href="https://en.wikipedia.org/wiki/Informatics_engineering"> Informatics Engineering</a> over at ULACIT, where I've finished coursework on the following subjects: OOP, Web & Mobile Dev, SQL & NoSQL DBA, Server & Cloud Administration and (some) Cybersecurity.</p>
	</div>
	<div class="grid grid-rows-3 grid-cols-1 md:grid-rows-1 md:grid-cols-3">
	<div class="mt-24 mx-2 flex flex-col items-center">
		<h3 class="text-4xl font-semibold">I'm working with:</h3>
		<SkillList style={'grid mt-8 gap-16 grid-cols-1 text-2xl items-center'} items={workingIcons} />
	</div>
	<div class="mt-24 mx-2 flex flex-col items-center">
		<h3 class="text-4xl font-semibold">I've worked with:</h3>
		<SkillList style={'grid mt-8 gap-16 grid-cols-1 text-2xl items-center'} items={workedIcons} />
	</div>
	<div class="mt-24 mx-2 flex flex-col items-center">
		<h3 class="text-4xl font-semibold">I'm learning these:</h3>
		<SkillList style={'grid mt-8 gap-16 grid-cols-1 text-2xl items-center'} items={learningIcons} />
	</div>
</div>
	<div class="md:mt-24 mx-2 flex flex-col items-center">
